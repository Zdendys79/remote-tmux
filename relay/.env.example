PORT=7901

# Relay server TLS certificate (for HTTPS/WSS)
SERVER_KEY=/home/remotes/remote-tmux/certs/relay.key
SERVER_CRT=/home/remotes/remote-tmux/certs/relay.crt

# CA certificate - used to verify agent client certificates
CA_CERT=/home/remotes/remote-tmux/certs/ca.crt

# Shared token for browser clients (no mTLS in browser)
CLIENT_TOKEN=change_me_browser_token
