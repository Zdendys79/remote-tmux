PORT_BROWSER=7901   # plain WS, only on localhost (behind Apache)
PORT_AGENT=7902    # HTTPS+mTLS, accessible from internet

# Relay server TLS certificate (for agent port 7902)
# Use relay-specific cert or the wildcard *.zdendys79.website
SERVER_KEY=/etc/letsencrypt/live/zdendys79.website/privkey.pem
SERVER_CRT=/etc/letsencrypt/live/zdendys79.website/fullchain.pem

# CA certificate - used to verify agent client certificates
CA_CERT=/home/remotes/remote-tmux/certs/ca.crt

# Shared token for browser clients
CLIENT_TOKEN=change_me_browser_token
