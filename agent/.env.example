# URL of the relay server
RELAY_URL=wss://tmux.zdendys79.website/ws

# This agent's name (CN must match the issued certificate)
AGENT_NAME=botka

# mTLS client certificate (issued by scripts/issue-cert.sh)
AGENT_KEY=/etc/remote-tmux/botka.key
AGENT_CERT=/etc/remote-tmux/botka.crt
CA_CERT=/etc/remote-tmux/ca.crt

# tmux sessions to expose (comma-separated); leave empty to auto-detect all
TMUX_SESSIONS=

# TTY consoles to expose (comma-separated, e.g. tty1,tty2); requires root
TTY_SESSIONS=
